{
	"name": "isa-doc",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"iconify": "node ./config/downloadIconify.js",
		"dev": "astro dev --port 4400",
		"build": "npm run iconify && astro build",
		"snapshot:gh-pages": "tsx ./scripts/snapshot-data.mts",
		"build:gh-pages": "npm run iconify && astro build --config astro.config.gh-pages.ts",
		"pub:gh-pages": "powershell -ExecutionPolicy Bypass -File ./scripts/PS1/pub-isa-doc/publish-gh-pages.ps1",
		"start": "node ./dist/server/entry.mjs",
		"preview": "astro preview",
		"typecheck": "tsc --noEmit",
		"verify:api": "tsx scripts/verify-api/verify_api.ts",
		"verify:api:patyia": "tsx scripts/verify-api-patyia/verify_api.ts",
		"verify:plan-order": "tsx scripts/verify-api/runs/run_plan_order.ts",
		"postman:gen": "tsx scripts/verify-api/postman/generate_postman_items.ts",
		"assets:upload": "node scripts/upload-assets-imgbb.mjs",
		"code-images:build": "tsx scripts/build-code-images.mjs"
	},
	"dependencies": {
		"@astrojs/node": "^9.x",
		"@astrojs/svelte": "^7.x",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.1",
		"@ingenieria_insoft/ispgen": "^1.0.x",
		"@ingenieria_insoft/ispsveltecomponents": "^x",
		"codemirror": "^6.0.2",
		"dotenv": "^16.6.1",
		"flowbite-svelte": "^1.33.1",
		"marked": "^18.0.2",
		"mssql": "^11.0.1",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"svelte": "^5.x"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.x",
		"@types/mssql": "^12.3.0",
		"astro": "^5.x",
		"tsx": "^4.21.0"
	}
}
