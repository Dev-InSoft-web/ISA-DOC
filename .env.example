# Conexión a BD (MSSQL) — copia este archivo a `.env` y rellena los valores.
# Mismas variables que usa el ISS en `local.settings.json`.
hostdb=mssql2.insoft.co
portdb=51433
userdb=SERVER-CLIENTES
passdb=
namedb=CLIENTES

# Reenvío del ejecutor SQL de la pestaña Bitácora a una API remota.
# Si `ISA_DB_REMOTE_URL` está definida, `/api/db/exec` reenvía la petición
# (POST {sql}) en lugar de abrir conexión `mssql` localmente. Útil cuando
# este host no alcanza al MSSQL directo (ej. fuera de VPN).
# ISA_DB_REMOTE_URL=https://api.example.com/db/exec
# ISA_DB_REMOTE_TOKEN=

# Conexión a la BD de PatyIA (AYUDASCP_IA). Misma convención que `hostdb/...`
# pero con prefijo `paty_` para no chocar con ClientesIS. Si se omiten, el
# endpoint `/api/patyia/db/exec` reusa el pool principal (`hostdb/...`).
# Estos valores se toman tal cual del `local.settings.json` de PatyIA.
# paty_hostdb=mssql2.insoft.co
# paty_portdb=51433
# paty_userdb=SERVER-AYUDASCP-IA
# paty_passdb=
# paty_namedb=AYUDASCP_IA_STAGING

# Reenvío remoto del ejecutor SQL de PatyIA (análogo a ISA_DB_REMOTE_URL).
# ISA_PATY_DB_REMOTE_URL=https://api.example.com/patyia/db/exec
# ISA_PATY_DB_REMOTE_TOKEN=

# PatyIA — OpenAI. ISA-DOC actúa como UI de gestión de la API de OpenAI
# usada por el backend AYUDASCP-IA. Mismas claves que viven en
# PatyIA/local.settings.json (`OPENAI_API_KEY`, `OPEN_AI_RESPONSES_URL`,
# `OPENAI_MODEL`, `PR_*`) pero con prefijo `paty_` para no chocar.
# paty_openai_api_key=sk-...
# paty_openai_responses_url=https://api.openai.com/v1/responses
# paty_openai_model=gpt-5.4
# paty_pr_tipo_consultas=pmpt_...
# paty_pr_general=pmpt_...
# paty_pr_extractor_consultas=pmpt_...
# paty_pr_clasificador_modulo=pmpt_...

