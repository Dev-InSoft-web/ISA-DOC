---
import "../styles/global.css";

interface Props {
   title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="es" class="dark">
   <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>{title}</title>
   </head>
   <body>
      <header class="isa-header">
         <span class="isa-logo">ISA</span>
         <span class="isa-sep">|</span>
         <nav class="isa-nav">
            <a href="/sql" class:list={["isa-nav-link", { active: currentPath === "/sql" }]}> SQL </a>
            <a href="/bitacora" class:list={["isa-nav-link", { active: currentPath === "/bitacora" }]}> Bitácora </a>
            <a href="/postman" class:list={["isa-nav-link", { active: currentPath === "/postman" }]}> Postman </a>
            <a href="/contapymeu" class:list={["isa-nav-link", { active: currentPath === "/contapymeu" }]}> Docs </a>
            <a href="/" class:list={["isa-nav-link", { active: currentPath === "/" }]}> Actions </a>
         </nav>
      </header>
      <main class="isa-main">
         <slot />
      </main>
   </body>
</html>

<style is:global>
   /* ISA-DOC: todos los ButtonIconify se renderizan con tamaño intrínseco */
   .is-button-iconify {
      width: fit-content !important;
      height: fit-content !important;
   }
</style>
<style>
   body {
      background: var(--is-bg-primary);
      color: var(--is-color);
      min-height: 100vh;
   }

   .isa-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 1.5rem;
      background: var(--is-bg-secondary);
      border-bottom: 1px solid var(--is-b-color);
   }

   .isa-logo {
      font-size: 1.25rem;
      font-weight: bold;
      color: var(--is-primary);
   }

   .isa-sep {
      opacity: 0.3;
   }

   .isa-nav {
      display: flex;
      gap: 0.5rem;
      font-size: 0.875rem;
   }

   .isa-nav-link {
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      text-decoration: none;
      color: inherit;
      transition: background 0.15s;
   }

   .isa-nav-link:hover {
      background: var(--is-bg-readonly);
   }

   .isa-nav-link.active {
      background: var(--is-primary);
      color: white;
   }

   .isa-main {
      padding: 0 1rem 1rem;
   }
</style>
