# Conexión a BD (MSSQL) — copia este archivo a `.env` y rellena los valores.
# Mismas variables que usa el ISS en `local.settings.json`.
hostdb=mssql2.insoft.co
portdb=51433
userdb=SERVER-CLIENTES
passdb=
namedb=CLIENTES

# Reenvío del ejecutor SQL de la pestaña Bitácora a una API remota.
# Si `ISA_DB_REMOTE_URL` está definida, `/api/db/exec` reenvía la petición
# (POST {sql}) en lugar de abrir conexión `mssql` localmente. Útil cuando
# este host no alcanza al MSSQL directo (ej. fuera de VPN).
# ISA_DB_REMOTE_URL=https://api.example.com/db/exec
# ISA_DB_REMOTE_TOKEN=

